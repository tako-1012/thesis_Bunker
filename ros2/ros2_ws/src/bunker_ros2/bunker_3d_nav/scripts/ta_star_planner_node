#!/usr/bin/env python3
"""
Wrapper executable to launch TA* planner via ros2 run.
Resolves module name collision with rosidl-generated bunker_3d_nav by loading the node module by file path.
"""

import os
import importlib.util


def run():
    here = os.path.dirname(os.path.abspath(__file__))
    pkg_root = os.path.dirname(here)
    target = os.path.join(pkg_root, 'bunker_3d_nav', 'bunker_3d_nav', 'ta_star_planner', 'ta_star_planner_node.py')
    if not os.path.exists(target):
        raise FileNotFoundError(f'Cannot locate TA* node file: {target}')
    spec = importlib.util.spec_from_file_location('bunker_3d_nav_internal.ta_star_planner_node', target)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)  # type: ignore
    mod.main()


if __name__ == "__main__":
    run()
